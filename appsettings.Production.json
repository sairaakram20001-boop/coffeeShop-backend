{
  "ConnectionStrings": {
    "DefaultConnection": "#{RENDER_DB_CONNECTION}#"
  },

  "Jwt": {
    "Key": "#{JWT_KEY}#",
    "Issuer": "CoffeeShopAPI",
    "Audience": "CoffeeShopClient",
    "DurationInMinutes": 60
  },

  "Cors": {
    "AllowedOrigins": ["https://timcoffeeshop.netlify.app"]
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "AllowedHosts": "*"
}
